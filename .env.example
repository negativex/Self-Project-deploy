# Database URL for Prisma (using SQLite)
DATABASE_URL="file:./dev.db"

# JWT Secret for authentication
JWT_SECRET="your-super-secret-jwt-key-here-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-here-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Admin credentials for seeding (if used)
ADMIN_EMAIL="admin@pharmacy.com"
ADMIN_PASSWORD="admin123"

# Node environment (e.g., development, production)
NODE_ENV="development"

# Nuxt server host and port
NUXT_HOST="0.0.0.0"
NUXT_PORT="3000"

# Example of other potential environment variables
# EXTERNAL_API_KEY="your_external_api_key"
# PAYMENT_GATEWAY_KEY="your_payment_gateway_key"
