# Ignore .git directory
.git

# Ignore node_modules (will be installed in Docker)
node_modules

# Ignore build output
.nuxt
.output
dist

# Ignore environment files
.env
.env.local
.env.*.local

# Ignore logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Ignore editor/IDE files
.vscode
.idea

# Ignore test reports
coverage
.nyc_output

# Ignore temporary files
*.tmp
*.log

# Ignore Prisma generated client (will be generated in Docker)
# This might be needed if you have a specific setup, but generally .prisma/client is ignored
# prisma/client

# Ignore specific database files if not intended to be copied
# dev.db
# dev.db-journal
